<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.server.ServerController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <children>
        <Label text="Server Console Logs" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
        
        <TextArea fx:id="serverLogs" editable="false" wrapText="true" VBox.vgrow="ALWAYS" style="-fx-font-family: monospace;" />
    </children>
</VBox>