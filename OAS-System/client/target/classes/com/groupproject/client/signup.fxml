<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.client.SignupController">
    <Label text="Welcome to OAS-App" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="usernameField" promptText="Username" maxWidth="200"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="200"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="200"/>
    <PasswordField fx:id="repeatPasswordField" promptText="Repeat Password" maxWidth = "200"/>
    
    <Button text="Sign Up" onAction="#handleSignUp"/>

    <HBox alignment="CENTER" spacing="10.0">
        <Label fx:id="signupSuggestion" textFill="gray" text="Already have an account? You gay"/>
        <Button text="Login" onAction="#switchToLogin"/>
    </HBox>
    
    <Label fx:id="statusLabel" textFill="red"/>
</VBox>