<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.client.SimpleChatAppController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>

    <children>
        <TextArea fx:id="chatHistory" editable="false" wrapText="true" VBox.vgrow="ALWAYS" />

        <HBox spacing="10.0">
            <children>
                <TextField fx:id="messageInput" promptText="Type a message..." HBox.hgrow="ALWAYS" onAction="#sendMessage" />

                <Button text="Send" onAction="#sendMessage" />
            </children>
        </HBox>
    </children>
</VBox>