<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox fx:id="" alignment="CENTER" prefHeight="488.0" prefWidth="652.0" spacing="20.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.client.LoginController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="login" />
    <Button onAction="#onHelloButtonClick" text="Log in" />
    <Label fx:id="signuptext" />
    <Button fx:id="Signupbutton" mnemonicParsing="false" onAction="#onSignupButtonClick" prefHeight="28.0" prefWidth="84.0" text="Sign up" />

</VBox>