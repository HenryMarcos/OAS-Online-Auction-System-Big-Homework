<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0"  prefHeight="220.0" prefWidth="330.0" styleClass="product-card" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.client.CardController">
    <children>
        <Region prefHeight="100.0" style="-fx-background-color: #f0f0f0; -fx-background-radius:8px;"/>
        <Label text="Name : " style="-fx-font-size:20px;-fx-font-weight:bold;"/>
        <Label text="Currentprice : " style="-fx-font-weight:bold; -fx-text-fill: #333333"/>
        <Label fx:id="timeleft" style="-fx-text-fill:#555555; -fx-font-size:12px;" />
    </children>
</VBox>