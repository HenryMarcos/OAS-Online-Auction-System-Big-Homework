<!-- SỬA LẠI ĐỊNH DẠNG CỦA LOG KHI GHI CHO PHÉP VIỆC DEBUG HOẶC THEO DÕI TRỞ NÊN DỄ DÀNG HƠN -->
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="info">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>