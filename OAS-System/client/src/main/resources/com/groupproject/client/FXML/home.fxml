<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.groupproject.client.HomeController">
    <top>
        <AnchorPane prefHeight="86.0" BorderPane.alignment="CENTER">
            <children>
                <Label alignment="CENTER" text="Auction System" textAlignment="JUSTIFY" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER_LEFT" spacing="5.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="0.0">
                    <children>
                        <Label text="Logged in as ">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label text="Cuong" textOverrun="CENTER_WORD_ELLIPSIS">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Button fx:id="logout" mnemonicParsing="false" onAction="#switchtologin" styleClass="logout-button" text="Log out" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="30.0" />
            </children>
        </AnchorPane>
    </top>
    <left>
        <AnchorPane prefWidth="122.0" BorderPane.alignment="CENTER" />
    </left>
    <center>
        <AnchorPane BorderPane.alignment="CENTER" />
    </center>
</BorderPane>